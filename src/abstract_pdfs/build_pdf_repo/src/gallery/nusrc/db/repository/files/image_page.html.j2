{# image_page.html.j2 — Single image page for a leaf dir with info.json #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | thedailydialectics</title>
  <meta name="description" content="{{ alt }}">
  <meta name="keywords" content="{{ keywords }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ alt }}">
  <meta property="og:image" content="{{ og_image }}">
  <script type="application/ld+json">{{ schema_json }}</script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #0d0d0d; color: #e0e0e0;
            display: flex; flex-direction: column; align-items: center; padding: 1.5rem 1rem; }
    nav.breadcrumb { font-size: .8rem; color: #888; margin-bottom: 1.5rem; width: 100%; max-width: 960px; }
    nav.breadcrumb a { color: #aaa; text-decoration: none; }
    nav.breadcrumb a:hover { color: #fff; }
    .container { max-width: 960px; width: 100%; }
    h1 { font-size: 1.4rem; margin-bottom: 1rem; color: #f0f0f0; }
    .img-wrap { background: #111; border-radius: 8px; overflow: hidden; margin-bottom: 1.2rem; }
    .img-wrap img { width: 100%; height: auto; display: block; }
    .caption { font-size: .85rem; color: #999; line-height: 1.6; margin-bottom: 1rem; }
    .description { font-size: .82rem; color: #777; line-height: 1.65; margin-bottom: 1.2rem; }
    .tags { display: flex; flex-wrap: wrap; gap: .3rem; margin-bottom: 1rem; }
    .tag { background: #1a1a1a; border: 1px solid #2e2e2e; border-radius: 4px;
            padding: .15rem .45rem; font-size: .7rem; color: #666; }
    .meta-row { font-size: .75rem; color: #555; }
    .meta-row a { color: #7aaeff; text-decoration: none; }
    .meta-row a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <nav class="breadcrumb">{{ breadcrumbs }}</nav>
  <div class="container">
    <h1>{{ title }}</h1>
  {%- if img_url %}
    <div class="img-wrap"><img src="{{ img_url }}" alt="{{ alt }}"></div>
  {%- endif %}
    <p class="caption">{{ alt }}</p>
  {%- if description %}
    <p class="description">{{ description }}</p>
  {%- endif %}
  {%- if keyword_tags %}
    <div class="tags">
    {%- for kw in keyword_tags %}
      <span class="tag">{{ kw }}</span>
    {%- endfor %}
    </div>
  {%- endif %}
    <div class="meta-row">
    {%- if license %} License: {{ license }}{% endif %}
    {%- if attribution %} · {{ attribution }}{% endif %}
    {%- if img_url %} · <a href="{{ img_url }}" target="_blank">Full image</a>{% endif %}
    </div>
  </div>
</body>
</html>
